<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                                   xmlns:app="http://schemas.android.com/apk/res-auto"
                                                   xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent"
                                                   android:layout_height="match_parent"
                                                   android:background="#FFFFFF">

    <ImageView
            android:id="@+id/ivBackSummary"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="16dp"
            android:contentDescription="Ícone de seta para voltar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <ImageView
            android:id="@+id/ivLogoSummary"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            app:srcCompat="@drawable/oscar_academy_award"
            app:tint="@color/primary_color"
            android:contentDescription="Logo do Oscar App"
            app:layout_constraintBottom_toBottomOf="@+id/ivBackSummary"
            app:layout_constraintEnd_toStartOf="@+id/ivProfileSummary"
            app:layout_constraintStart_toEndOf="@+id/ivBackSummary"
            app:layout_constraintTop_toTopOf="@+id/ivBackSummary" />

    <ImageView
            android:id="@+id/ivProfileSummary"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="16dp"
            app:srcCompat="@drawable/outline_account_circle_24"
            app:tint="@color/grey"
            android:contentDescription="Ícone de perfil do usuário"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    <TextView
            android:layout_width="match_parent"
            android:gravity="center"
            android:textSize="20dp"
            android:layout_height="wrap_content" android:id="@+id/welcomeText"
            app:layout_constraintTop_toBottomOf="@+id/ivLogoSummary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="12dp"
            app:layout_constraintHorizontal_bias="0.0"/>

    <androidx.cardview.widget.CardView
            android:id="@+id/cardImagemDestaque"
            android:layout_width="match_parent"
            android:layout_marginHorizontal="20dp"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/welcomeText"
            app:layout_constraintEnd_toEndOf="parent">

        <ImageView
                android:id="@+id/imgDestaque"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:srcCompat="@drawable/oscar_banner"
                android:scaleType="centerCrop"/>

    </androidx.cardview.widget.CardView>

    <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/containerTicket"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="20dp"
            app:layout_constraintTop_toBottomOf="@id/cardImagemDestaque"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/containerLeave">

        <ImageView
                android:id="@+id/imgIconeTicket"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/txtNumeroTicket"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_chainStyle="packed"
                app:srcCompat="@drawable/confirmation_number_24dp"
                app:tint="@color/primary_color"
        />

        <TextView
                android:id="@+id/txtNumeroTicket"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0"
                android:textSize="32sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/imgIconeTicket"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>



    <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/containerLeave"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintTop_toBottomOf="@id/cardImagemDestaque"
            app:layout_constraintStart_toEndOf="@id/containerTicket"
            app:layout_constraintEnd_toEndOf="parent">

        <ImageView
                android:id="@+id/imgIconeLeave"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/txtNumeroLeave"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_chainStyle="packed"
                app:srcCompat="@drawable/outline_exit_to_app_24"
                app:tint="@color/primary_color"
        />

        <TextView
                android:id="@+id/txtNumeroLeave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Sair"
                android:textSize="32sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/imgIconeLeave"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>